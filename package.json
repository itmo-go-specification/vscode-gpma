{
  "name": "acsl-syntax-highlighting",
  "displayName": "ACSL Syntax Highlighting",
  "description": "Syntax highlighting for ANSI/ISO C Specification Language (ACSL) annotations in Go files",
  "version": "0.1.0",
  "publisher": "go-specification-lang",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ya-vscode-gpma.helloWorld",
        "title": "Hello World"
      }
    ],
    "languages": [
      {
        "id": "acsl",
        "aliases": [
          "ACSL",
          "acsl",
          "Go with ACSL"
        ],
        "extensions": [
          ".acsl"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "go-acsl",
        "aliases": [
          "Go with ACSL",
          "Go+ACSL"
        ],
        "extensions": [
          ".go.acsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "acsl",
        "scopeName": "source.acsl",
        "path": "./syntaxes/go-with-acsl.tmLanguage.json"
      },
      {
        "language": "go-acsl",
        "scopeName": "source.acsl",
        "path": "./syntaxes/go-acsl.tmLanguage.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/go-specification-lang.git"
  },
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "npm run generate && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "generate": "cd ./tools/grammar-gen && go run . -grammar ../../vendor/go-specification-lang/framework/gosl/front/grammar/ACSL.g4 -output ../../syntaxes/acsl.tmLanguage.json && go run . -grammar ../../vendor/go-specification-lang/framework/gosl/front/grammar/ACSL.g4 -include-go -output ../../syntaxes/go-acsl.tmLanguage.json && cp ../../syntaxes/go-acsl.tmLanguage.json ../../syntaxes/go-with-acsl.tmLanguage.json",
    "build": "npm run generate && npx vsce package"
  },
  "keywords": [],
  "author": "",
  "bugs": {
    "url": "https://github.com/your-org/go-specification-lang/issues"
  },
  "homepage": "https://github.com/your-org/go-specification-lang#readme",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}